# Supabase project credentials.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Supabase Storage bucket used for project and profile files.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="realproyect-files"

# Server-only key used by admin API routes. Never expose it as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Public app URL used for invitation and password recovery redirects.
NEXT_PUBLIC_SITE_URL="https://YOUR_DOMAIN"

# Resend credentials used by server routes to send branded transactional emails.
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
RESEND_FROM_EMAIL="Pixel Project <notificaciones@YOUR_DOMAIN>"
