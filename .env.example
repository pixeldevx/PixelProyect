# Supabase public project credentials.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Supabase Storage bucket used for project and profile files.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="pixel-project-files"

# Document storage provider. Keep Supabase by default; set to "s3" to route new uploads to Amazon S3.
DOCUMENT_STORAGE_PROVIDER="supabase"

# Amazon S3 document storage. Server-only; never prefix credentials with NEXT_PUBLIC_*.
AWS_REGION="us-east-1"
AWS_S3_BUCKET="YOUR_PRIVATE_DOCUMENT_BUCKET"
AWS_S3_PREFIX="pixel-project"
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# Optional limits for the document manager.
DOCUMENT_STORAGE_MAX_FILE_SIZE_MB="50"
DOCUMENT_STORAGE_ALLOWED_TYPES=""

# Server-only key used by admin API routes. Never expose it as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Public app URL used for invitation and password recovery redirects.
NEXT_PUBLIC_SITE_URL="https://YOUR_DOMAIN"

# Comma-separated emails allowed as emergency bootstrap admins.
# Keep the public and server value aligned if you need client-side bootstrap checks.
BOOTSTRAP_ADMIN_EMAILS="admin@example.com"
NEXT_PUBLIC_BOOTSTRAP_ADMIN_EMAILS="admin@example.com"

# Resend credentials used by server routes to send branded transactional emails.
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
RESEND_FROM_EMAIL="Pixel Project <notifications@YOUR_DOMAIN>"

# PWA push notifications.
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
WEB_PUSH_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"
WEB_PUSH_SUBJECT="mailto:admin@example.com"
