{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project in the system",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the project"
        },
        "description": {
          "type": "string",
          "description": "Description of the project"
        },
        "status": {
          "type": "string",
          "enum": ["active", "completed", "on-hold"],
          "description": "Current status of the project"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the project was created"
        },
        "updatedAt": {
          "type": "timestamp",
          "description": "When the project was last updated"
        },
        "ownerId": {
          "type": "string",
          "description": "ID of the user who owns the project"
        },
        "assignedUsers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user IDs assigned to this project"
        }
      },
      "required": ["name", "status", "createdAt", "updatedAt", "ownerId"]
    },
    "ProjectDocument": {
      "title": "Project Document",
      "description": "A document associated with a project",
      "type": "object",
      "properties": {
        "projectId": {
          "type": "string",
          "description": "ID of the project this document belongs to"
        },
        "name": {
          "type": "string",
          "description": "Name of the document"
        },
        "type": {
          "type": "string",
          "enum": ["contract", "proposal", "other"],
          "description": "Type of the document"
        },
        "url": {
          "type": "string",
          "description": "Download URL of the document in Firebase Storage"
        },
        "uploadedAt": {
          "type": "timestamp",
          "description": "When the document was uploaded"
        },
        "uploadedBy": {
          "type": "string",
          "description": "ID of the user who uploaded the document"
        }
      },
      "required": ["projectId", "name", "type", "url", "uploadedAt", "uploadedBy"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A follow-up activity for a user in a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "assignedTo": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" },
        "createdBy": { "type": "string" }
      },
      "required": ["projectId", "assignedTo", "title", "status", "createdAt", "updatedAt", "createdBy"]
    },
    "RateCard": {
      "title": "Rate Card",
      "description": "A rate card for indicators",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "indicator": { "type": "string" },
        "rate": { "type": "number" },
        "currency": { "type": "string" },
        "currentValue": { "type": "number", "description": "Accumulated units for this rate card" },
        "reworkValue": { "type": "number", "description": "Accumulated penalty units for returned steps" },
        "userStats": { "type": "object", "description": "Accumulated units per user for this rate card. Keys are user IDs, values are numbers." },
        "userReworkStats": { "type": "object", "description": "Accumulated penalty units per user for returned steps. Keys are user IDs, values are numbers." },
        "createdAt": { "type": "timestamp" },
        "createdBy": { "type": "string" }
      },
      "required": ["projectId", "name", "indicator", "rate", "currency", "createdAt", "createdBy"]
    },
    "Task": {
      "title": "Task",
      "description": "A task in a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "timestamp" },
        "endDate": { "type": "timestamp" },
        "assignedTo": { "type": "string" },
        "indicator": { "type": "string" },
        "type": { "type": "string", "enum": ["state", "quantitative", "workflow"] },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed", "stuck"] },
        "progress": { "type": "number" },
        "indicatorValue": { "type": "number" },
        "currentValue": { "type": "number" },
        "rateCardId": { "type": "string", "description": "Associated rate card for the entire workflow" },
        "unitsToAdd": { "type": "number", "description": "Units to add when workflow is completed" },
        "workflowSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "assignedTo": { "type": "string" },
              "label": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "approved", "returned"] },
              "rateCardId": { "type": "string", "description": "Associated rate card for this step" },
              "unitsToAdd": { "type": "number", "description": "Units to add when step is approved" }
            }
          }
        },
        "currentStepIndex": { "type": "number" },
        "workflowCycles": { "type": "number" },
        "currentCycle": { "type": "number" },
        "isParentTask": { "type": "boolean" },
        "totalCycles": { "type": "number" },
        "parentTaskId": { "type": "string" },
        "cycleNumber": { "type": "number" },
        "documentation": { "type": "string" },
        "externalWorkflowId": { "type": "string" },
        "initialObservation": { "type": "string" },
        "startDocumentId": { "type": "string" },
        "workflowHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stepIndex": { "type": "number" },
              "userId": { "type": "string" },
              "action": { "type": "string", "enum": ["start", "approve", "return"] },
              "comment": { "type": "string" },
              "timestamp": { "type": "timestamp" }
            }
          }
        },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" },
        "createdBy": { "type": "string" }
      },
      "required": ["projectId", "title", "startDate", "endDate", "assignedTo", "status", "progress", "createdAt", "updatedAt", "createdBy"]
    },
    "AlertRule": {
      "title": "Alert Rule",
      "description": "A rule defining when to trigger an alert",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "conditionType": { "type": "string", "enum": ["overdue", "inactive"] },
        "thresholdDays": { "type": "number" },
        "notifyEmail": { "type": "boolean" },
        "notifyInApp": { "type": "boolean" },
        "createdAt": { "type": "timestamp" },
        "createdBy": { "type": "string" }
      },
      "required": ["projectId", "name", "conditionType", "thresholdDays", "notifyInApp", "createdAt", "createdBy"]
    },
    "Alert": {
      "title": "Alert",
      "description": "An alert instance generated for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "ruleId": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["warning", "error", "info"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "ruleId", "projectId", "taskId", "message", "type", "isRead", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A billing record for a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "timestamp" },
        "status": { "type": "string", "enum": ["pending", "paid", "cancelled"] },
        "createdAt": { "type": "timestamp" },
        "createdBy": { "type": "string" }
      },
      "required": ["projectId", "invoiceNumber", "amount", "date", "status", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores all projects"
    },
    "/projects/{projectId}/documents/{documentId}": {
      "schema": { "$ref": "#/entities/ProjectDocument" },
      "description": "Stores documents for a specific project"
    },
    "/projects/{projectId}/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Stores activities for a specific project"
    },
    "/projects/{projectId}/rateCards/{rateCardId}": {
      "schema": { "$ref": "#/entities/RateCard" },
      "description": "Stores rate cards for a specific project"
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores tasks for a specific project"
    },
    "/alert_rules/{ruleId}": {
      "schema": { "$ref": "#/entities/AlertRule" },
      "description": "Stores alert rules"
    },
    "/alerts/{alertId}": {
      "schema": { "$ref": "#/entities/Alert" },
      "description": "Stores generated alerts for users"
    },
    "/projects/{projectId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "Stores billing records for a specific project"
    }
  }
}
